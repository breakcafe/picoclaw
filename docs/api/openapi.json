            "type": "string",
            "enum": [
              "error"
            ]
          },
          "error": {
            "type": "string"
          }
        }
      },
      "TaskCheckErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checked",
          "executed",
          "remaining"
        ],
        "properties": {
          "checked": {
            "type": "integer",
            "minimum": 1
          },
          "executed": {
            "$ref": "#/components/schemas/TaskCheckErrorExecuted"
          },
          "remaining": {
            "type": "integer",
            "minimum": 0
          }
        }
